# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# LLM
ANTHROPIC_API_KEY=sk-ant-xxx

# Embeddings (Prompt Lab learning loop — similarity retrieval across iterations)
# OpenAI text-embedding-3-small, 1536 dim, $0.02/M tokens
OPENAI_API_KEY=

# Video Generation Providers
RUNWAY_API_KEY=
KLING_API_KEY=
LUMA_API_KEY=

# Video Assembly (Shotstack)
# SHOTSTACK_ENV=stage (sandbox, default) or production
# Use SHOTSTACK_API_KEY_STAGE for sandbox testing; SHOTSTACK_API_KEY for production
SHOTSTACK_ENV=stage
SHOTSTACK_API_KEY_STAGE=
SHOTSTACK_API_KEY=

# Notifications
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
NOTIFICATION_FROM_EMAIL=noreply@reelready.com
WEBHOOK_SECRET=

# Pipeline Config
MAX_RETRIES_PER_CLIP=2
QC_CONFIDENCE_THRESHOLD=0.75
QC_AUTO_APPROVE_THRESHOLD=0.95
DEFAULT_CLIP_DURATION=3.5
TRANSITION_DURATION=0.4
