{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/properties/[id]",
      "regex": "^/api/properties/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/properties/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/properties/[id]/rerun",
      "regex": "^/api/properties/([^/]+?)/rerun(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/properties/(?<nxtPid>[^/]+?)/rerun(?:/)?$"
    },
    {
      "page": "/api/properties/[id]/status",
      "regex": "^/api/properties/([^/]+?)/status(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/properties/(?<nxtPid>[^/]+?)/status(?:/)?$"
    },
    {
      "page": "/api/scenes/[id]",
      "regex": "^/api/scenes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/scenes/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/scenes/[id]/approve",
      "regex": "^/api/scenes/([^/]+?)/approve(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/scenes/(?<nxtPid>[^/]+?)/approve(?:/)?$"
    },
    {
      "page": "/api/scenes/[id]/retry",
      "regex": "^/api/scenes/([^/]+?)/retry(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/scenes/(?<nxtPid>[^/]+?)/retry(?:/)?$"
    },
    {
      "page": "/api/scenes/[id]/skip",
      "regex": "^/api/scenes/([^/]+?)/skip(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/scenes/(?<nxtPid>[^/]+?)/skip(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}